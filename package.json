{
  "name": "broadridge-site-scanner",
  "version": "0.1.0",
  "description": "DOM-first live site scanner for Broadridge FA sites — validates links, CTAs, layout, and compares original vs migrated sites",
  "author": "veredlid",
  "license": "UNLICENSED",
  "private": true,
  "type": "module",
  "engines": {
    "node": ">=18.0.0"
  },
  "bin": {
    "br-scanner": "./dist/index.js"
  },
  "scripts": {
    "build": "tsc",
    "start": "node dist/index.js",
    "dev": "tsx src/index.ts",
    "scan": "tsx src/index.ts scan",
    "compare": "tsx src/index.ts compare",
    "compare-sites": "tsx src/index.ts compare-sites",
    "lint": "eslint src/",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "playwright": "^1.49.0",
    "commander": "^12.1.0",
    "fast-xml-parser": "^4.5.0",
    "chalk": "^5.3.0",
    "ora": "^8.1.0"
  },
  "devDependencies": {
    "typescript": "^5.6.0",
    "tsx": "^4.19.0",
    "@types/node": "^22.0.0",
    "eslint": "^9.0.0"
  }
}
