{
  "name": "broadridge-site-scanner",
  "version": "0.1.0",
  "description": "DOM-first live site scanner for Broadridge FA sites — validates links, CTAs, layout, and compares original vs migrated sites",
  "author": "veredlid",
  "license": "UNLICENSED",
  "private": true,
  "type": "module",
  "engines": {
    "node": ">=18.0.0"
  },
  "bin": {
    "br-scanner": "./dist/index.js"
  },
  "scripts": {
    "build": "tsc",
    "build:server": "cd server && npm run build",
    "build:client": "cd client && npm run build",
    "build:all": "npm run build && npm run build:server && npm run build:client",
    "start": "node server/dist/index.js",
    "watch:scanner": "tsc -w --preserveWatchOutput",
    "watch:server": "cd server && tsc -w --preserveWatchOutput",
    "dev:server": "node --watch-path=dist --watch-path=server/dist server/dist/index.js",
    "dev:client": "cd client && npm run dev",
    "dev": "npm run build:all && npx concurrently --kill-others-on-fail -n scanner,server-ts,api,client -c blue,cyan,green,magenta \"npm run watch:scanner\" \"npm run watch:server\" \"npm run dev:server\" \"npm run dev:client\"",
    "scan": "tsc && node dist/index.js scan",
    "compare": "tsc && node dist/index.js compare",
    "compare-sites": "tsc && node dist/index.js compare-sites",
    "lint": "eslint src/",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@types/jsdom": "^28.0.0",
    "chalk": "^5.3.0",
    "commander": "^12.1.0",
    "fast-xml-parser": "^4.5.0",
    "jsdom": "^29.0.0",
    "ora": "^8.1.0",
    "playwright": "^1.49.0"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "concurrently": "^9.1.0",
    "eslint": "^9.0.0",
    "tsx": "^4.19.0",
    "typescript": "^5.6.0"
  }
}
